node_modules/
importmap.js
.claude

# Not committed so every build re-resolves the "latest"-pinned deps
# (colorjs.io, color-elements) to their newest published versions.
package-lock.json

# Ignore generated HTML files, but keep hand-authored app pages (index.html etc.)
# at any nesting depth. client_modules has its own .gitignore (*), so its bundled
# HTML stays ignored regardless of these.
*.html
!*.tpl.html
!*/*.html
!*/*/*.html
